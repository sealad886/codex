# Environment configuration for Codex CLI
# Copy this file to .env and customize as needed

# OpenAI Configuration (required for API access)
# Get your API key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-api-key-here

# Model Configuration
# Default model to use (optional, can be overridden via CLI)
# CODEX_MODEL=gpt-5-codex

# Logging Configuration
# Set log level: error, warn, info, debug, trace
RUST_LOG=info

# Sandbox Configuration
# Default sandbox mode: read-only, workspace-write, danger-full-access
# CODEX_SANDBOX_MODE=read-only

# Approval Policy
# Default approval policy: untrusted, on-failure, on-request, never
# CODEX_APPROVAL_POLICY=untrusted

# Working Directory
# Override default working directory
# CODEX_WORKDIR=/path/to/your/project

# Performance Settings
# Number of parallel requests (default: 4)
# CODEX_MAX_CONCURRENT_REQUESTS=4

# Timeout settings (in seconds)
# CODEX_REQUEST_TIMEOUT=30
# CODEX_CONNECT_TIMEOUT=10

# Feature Flags
# Enable/disable experimental features
# CODEX_ENABLE_WEB_SEARCH=false
# CODEX_ENABLE_EXPERIMENTAL_FEATURES=false

# Development/Debug Settings
# Enable additional debug output
# CODEX_DEBUG=false

# Disable network access in sandbox (for testing)
# CODEX_SANDBOX_NETWORK_DISABLED=1

# Custom Configuration Path
# Override default config file location (~/.codex/config.toml)
# CODEX_CONFIG_PATH=/path/to/custom/config.toml

# Authentication Method
# Force specific authentication method: api-key, chatgpt
# CODEX_AUTH_METHOD=chatgpt

# Notification Settings
# Command to run for notifications (e.g., desktop notifications)
# CODEX_NOTIFY_COMMAND="notify-send 'Codex' 'Task completed'"

# Model Context Protocol (MCP) Settings
# Enable MCP server connections
# CODEX_ENABLE_MCP=true

# OpenAI Base URL Override (for custom endpoints)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI Configuration (if using Azure)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-api-key
# AZURE_OPENAI_API_VERSION=2024-02-15-preview